{
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/index" },
    { "source": "/api/ocr", "destination": "/api/index" },
    { "source": "/api/parse_pdf", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}
